# Required — all Claude API calls (spec builder, worker adapter, UX evaluators, debater)
ANTHROPIC_API_KEY=sk-ant-...

# Optional — override artifact storage location (default: ./runs)
# RUNS_DIR=./runs

# Optional — enable Docker isolation, one container per candidate
# DOCKER_ENV=1

# Optional — POST submission payload to this URL after each run
# SUBMIT_WEBHOOK_URL=https://webhook.site/your-unique-id
